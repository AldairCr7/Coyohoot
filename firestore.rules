// firestore.rules
// Copia estas reglas en Firebase Console > Firestore Database > Rules.
//
// Nota: Coyohoot está pensado como app estática para GitHub Pages. Estas reglas son
// permisivas para conservar compatibilidad con el flujo actual sin Firebase Auth.
// Para producción fuerte, migra las cuentas admin a Firebase Authentication y limita
// escrituras por request.auth.uid.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /coyohoot_admin_users/{uid} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /coyohoots/{quizId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /participants/{participantId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }

      match /responses/{responseId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }
  }
}
